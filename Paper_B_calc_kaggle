    "import numpy as np\n",
    "from scipy.integrate import solve_ivp, quad\n",
    "from scipy.optimize import brentq\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Schrodinger-Poisson system in spherical symmetry\n",
    "# for the ground state soliton.\n",
    "#\n",
    "# psi(r) = R(r) * e^{-i*mu*t}\n",
    "# where mu is the eigenvalue (chemical potential)\n",
    "#\n",
    "# Dimensionless units:\n",
    "# length: r0 = 1/(m * sqrt(4*pi*G*rho_c))\n",
    "# We use the standard rescaling for fDM solitons.\n",
    "#\n",
    "# The system reduces to:\n",
    "# R'' + (2/r)*R' - 2m*(V - mu)*R = 0\n",
    "# V'' + (2/r)*V' = 4*pi*G*m*R^2\n",
    "#\n",
    "# In dimensionless form (Chavanis 2011 / Schive 2014):\n",
    "# u'' + (2/x)*u' + (e - phi)*u = 0\n",
    "# phi'' + (2/x)*phi' = -u^2\n",
    "#\n",
    "# where u = r*R (removes 1/r singularity)\n",
    "# x = dimensionless radius\n",
    "# e = dimensionless eigenvalue\n",
    "# phi = dimensionless gravitational potential\n",
    "\n",
    "# Boundary conditions:\n",
    "# u(0) = 0, u'(0) = u0 (shooting parameter)\n",
    "# phi(0) = phi0 (shooting parameter), phi'(0) = 0\n",
    "# As x -> inf: u -> 0, phi -> 0\n",
    "\n",
    "# We shoot from x=0 outward and find\n",
    "# (u0, phi0) such that u -> 0 at large x.\n",
    "\n",
    "def soliton_rhs(x, y, e):\n",
    "    \"\"\"\n",
    "    y = [u, u', phi, phi']\n",
    "    u = r * R(r)\n",
    "    \"\"\"\n",
    "    u, du, phi, dphi = y\n",
    "    if x < 1e-10:\n",
    "        # L'Hopital at origin\n",
    "        d2u   = (e - phi) * u / 3.0\n",
    "        d2phi = -u**2 / 3.0\n",
    "    else:\n",
    "        d2u   = -(2.0/x)*du + (phi - e)*u\n",
    "        d2phi = -(2.0/x)*dphi - u**2\n",
    "    return [du, d2u, dphi, d2phi]\n",
    "\n",
    "def shoot(u0, phi0, e, x_max=50.0, n=5000):\n",
    "    \"\"\"\n",
    "    Integrate outward from x=0.\n",
    "    Returns solution object.\n",
    "    \"\"\"\n",
    "    x_span = (1e-6, x_max)\n",
    "    x_eval = np.linspace(1e-6, x_max, n)\n",
    "    y0 = [u0 * 1e-6,   # u(0) ~ 0\n",
    "          u0,           # u'(0) = u0\n",
    "          phi0,         # phi(0)\n",
    "          0.0]          # phi'(0) = 0\n",
    "    sol = solve_ivp(soliton_rhs, x_span, y0,\n",
    "                    args=(e,),\n",
    "                    t_eval=x_eval,\n",
    "                    method='DOP853',\n",
    "                    rtol=1e-8, atol=1e-10)\n",
    "    return sol\n",
    "\n",
    "# Find the ground state:\n",
    "# Fix u0 = 1 (normalisation freedom)\n",
    "# Scan phi0 to find solution where\n",
    "# u -> 0 smoothly at large x.\n",
    "# The eigenvalue e is determined by phi0.\n",
    "\n",
    "# Known result from literature:\n",
    "# e ~ -0.69, phi0 ~ -0.69 (Schive 2014)\n",
    "# Let us find it by shooting.\n",
    "\n",
    "u0_fixed = 1.0\n",
    "\n",
    "def u_at_xmax(phi0, e=-0.69, x_max=30.0):\n",
    "    sol = shoot(u0_fixed, phi0, e, x_max)\n",
    "    return sol.y[0, -1]\n",
    "\n",
    "# Scan phi0\n",
    "phi0_vals = np.linspace(-1.5, -0.1, 50)\n",
    "u_vals    = []\n",
    "for p in phi0_vals:\n",
    "    try:\n",
    "        u_end = u_at_xmax(p)\n",
    "        u_vals.append(u_end)\n",
    "    except:\n",
    "        u_vals.append(np.nan)\n",
    "\n",
    "u_vals = np.array(u_vals)\n",
    "\n",
    "# Find sign change\n",
    "print(\"Scanning phi0 for ground state:\")\n",
    "print(f\"{'phi0':>8} {'u(xmax)':>12}\")\n",
    "print(\"-\" * 22)\n",
    "for i in range(len(phi0_vals)):\n",
    "    if not np.isnan(u_vals[i]):\n",
    "        print(f\"{phi0_vals[i]:>8.3f} \"\n",
    "              f\"{u_vals[i]:>12.4e}\")\n",
    "              "
