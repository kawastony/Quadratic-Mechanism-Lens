"output_type":"stream"}],"execution_count":123},{"cell_type":"code","source":"# For each phi, compute:\n# max BAO deviation\n# S8 value\n# w0 value\n# Then find the consistent window\n\nphi_fracs = [0.30, 0.32, 0.34,\n             0.36, 0.38, 0.391,\n             0.42, 0.46]\n\nz_bao_scan = [0.295, 0.510, 0.706,\n              0.930, 1.317, 2.330]\n\nprint(f\"{'phi/pi':>7} {'w0':>7} \"\n      f\"{'S8':>7} {'maxBAO%':>8} \"\n      f\"{'status':>12}\")\nprint(\"-\" * 50)\n\nfor frac in phi_fracs:\n    phi_ini = frac * np.pi * f_E\n    try:\n        L4, sol_loc = find_Lambda4_thawing(phi_ini)\n        Lambda4_global = L4\n\n        # Build H(z)\n        N_s = np.linspace(np.log(1e-4), 0.0, 500)\n        a_s = np.exp(N_s)\n        H_s = [np.sqrt(abs(H_sq(np.exp(N),\n               *sol_loc.sol(N)))) for N in N_s]\n        H_s = np.array(H_s)\n        Hi_s = interp1d(1.0/a_s[::-1]-1.0,\n                        H_s[::-1],\n                        kind='cubic',\n                        fill_value='extrapolate',\n                        bounds_error=False)\n\n        # rho_phi today\n        ph0, dph0 = sol_loc.sol(0.0)\n        H2_0 = H_sq(1.0, ph0, dph0)\n        KE0  = 0.5 * H2_0 * dph0**2\n        PE0  = V(ph0)\n        rho0 = KE0 + PE0\n        w0   = (KE0 - PE0) / rho0\n\n        def H_ref(z):\n            a = 1.0/(1.0+z)\n            return np.sqrt(Omega_m0/a**3\n                           + rho0)\n\n        # BAO max deviation\n        devs = []\n        for z in z_bao_scan:\n            dvT = DV(z, Hi_s)\n            dvR = DV(z, H_ref)\n            devs.append(abs(dvT/dvR - 1)*100)\n        max_dev = max(devs)\n\n        # Growth and S8\n        a_ini = 1.0/51.0\n        aev   = np.linspace(a_ini, 1.0, 500)\n\n        def g_T(a, y):\n            D, Dp = y\n            H  = Hi_s(1.0/a - 1.0)\n            da = a * 1e-4\n            dH = (Hi_s(1.0/(a+da)-1.0) -\n                  Hi_s(1.0/(a-da)-1.0))/(2*da)\n            c1 = -(3.0/a + dH/H)\n            c2 =  1.5*Omega_m0/(a**2*H**2)\n            return [Dp, c1*Dp + c2*D]\n\n        def g_R(a, y):\n            D, Dp = y\n            H  = H_ref(1.0/a - 1.0)\n            da = a * 1e-4\n            dH = (H_ref(1.0/(a+da)-1.0) -\n                  H_ref(1.0/(a-da)-1.0))/(2*da)\n            c1 = -(3.0/a + dH/H)\n            c2 =  1.5*Omega_m0/(a**2*H**2)\n            return [Dp, c1*Dp + c2*D]\n\n        sT = solve_ivp(g_T, [a_ini,1.0],\n                       [a_ini,1.0], t_eval=aev,\n                       rtol=1e-6, atol=1e-8)\n        sR = solve_ivp(g_R, [a_ini,1.0],\n                       [a_ini,1.0], t_eval=aev,\n                       rtol=1e-6, atol=1e-8)\n\n        DT = sT.y[0,-1]\n        DR = sR.y[0,-1]\n        S8 = 0.811 * (DT/DR) * np.sqrt(\n             Omega_m0/0.3)\n\n        # Status\n        bao_ok = max_dev < 1.0\n        w_ok   = -0.94 < w0 < -0.80\n        if bao_ok and w_ok:\n            status = \"CONSISTENT\"\n        elif bao_ok:\n            status = \"BAO ok\"\n        elif w_ok:\n            status = \"DESI ok\"\n        else:\n            status = \"tension\"\n\n        print(f\"{frac:>7.3f} {w0:>7.4f} \"\n              f\"{S8:>7.4f} {max_dev:>8.3f} \"\n              f\"{status:>12}\")\n\n    except Exception as e:\n        print(f\"{frac:>7.3f}  failed: {e}\")\n        ","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-14T09:01:04.893213Z","iopub.execute_input":"2026-03-14T09:01:04.893478Z","iopub.status.idle":"2026-03-14T09:01:05.737116Z","shell.execute_reply.started":"2026-03-14T09:01:04.893451Z","shell.execute_reply":"2026-03-14T09:01:05.735990Z"}},"outputs":[{"name":"stdout","text":" phi/pi      w0      S8  maxBAO%       status\n--------------------------------------------------\n  0.300 -0.6518  0.8264    4.182      tension\n  0.320 -0.7386  0.8282    3.070      tension\n  0.340 -0.7924  0.8292    2.403      tension\n  0.360 -0.8301  0.8300    1.946      DESI ok\n  0.380 -0.8583  0.8305    1.611      DESI ok\n  0.391 -0.8710  0.8308    1.461      DESI ok\n  0.420 -0.8978  0.8313    1.150      DESI ok\n  0.460 -0.9241  0.8317    0.850   CONSISTENT\n","output_type":"stream"}],"execution_count":124},{"cell_type":"code","source":"import numpy as np\nfrom scipy.optimize import brentq\n\n# Physical constants\nH0_eV   = 1.44e-33   # eV\nm_fDM   = 1e-22      # eV\nm_over_H0 = m_fDM / H0_eV\n\nOmega_m0 = 0.315\nOmega_r0 = 9.1e-5\nOmega_L0 = 1.0 - Omega_m0 - Omega_r0\n\ndef E(z):\n    return np.sqrt(\n        Omega_m0*(1+z)**3 +\n        Omega_r0*(1+z)**4 +\n        Omega_L0)\n\n# Solve m = H(z_osc)\ndef eq(z):\n    return E(z) - m_over_H0\n\n# Search range\nz_lo, z_hi = 1e6, 1e14\n\nprint(f\"m_fDM          = {m_fDM:.2e} eV\")\nprint(f\"H0             = {H0_eV:.2e} eV\")\nprint(f\"m/H0           = {m_over_H0:.3e}\")\nprint()\n\ntry:\n    z_osc = brentq(eq, z_lo, z_hi)\n    print(f\"z_osc          = {z_osc:.3e}\")\n    print(f\"z_eq           = 3400\")\n    print(f\"z_CMB          = 1100\")\n    print()\n    if z_osc > 3400:\n        print(\"STATUS: PASS\")\n        print(\"Field oscillates before\")\n        print(\"matter-radiation equality.\")\n        print(\"Behaves as CDM at CMB.\")\n    else:\n        print(\"STATUS: FAIL\")\n        print(\"Field still frozen at z_eq.\")\n        print(\"Does not mimic CDM.\")\nexcept Exception as e:\n    print(f\"Root not found: {e}\")\n    print(\"Checking E(z) at boundaries:\")\n    for z_t in [1e6, 1e8, 1e10, 1e12]:\n        print(f\"  E({z_t:.0e}) = {E(z_t):.3e}\")\n\nprint()\n\n# What decay constant f_DM is needed?\n# For quadratic potential: m is free\n# For cosine potential: m ~ Lambda^2/f\n# If we want m = 10^{-22} eV\n# and Lambda ~ meV scale:\n# f_DM = Lambda^2 / m\n\nLambda_cosm = 2.24e-3   # eV, cosmological\nf_DM_cosine = Lambda_cosm**2 / m_fDM\n\nprint(f\"If cosine potential:\")\nprint(f\"Lambda_cosm    = {Lambda_cosm:.2e} eV\")\nprint(f\"f_DM required  = {f_DM_cosine:.3e} eV\")\n\n# Convert to Planck units\nM_Pl_eV = 1.22e28      # eV\nprint(