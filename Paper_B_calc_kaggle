ylabel(\n    r'ρ  ($10^7\\,M_\\odot\\,\\mathrm{kpc}^{-3}$)')\nax11.set_title('GP  —  density ρ(r)',\n               fontweight='bold')\nax11.set_xlim(0, 8)\nax11.grid(True, alpha=0.3)\n\nax12 = fig.add_subplot(gs[1,2])\nax12.plot(z_tf, w_tf,\n          color=c_tifa, lw=2,\n          label='TIFA w(z)')\nax12.axhline(\n    w_desi, color='r',\n    ls='--', lw=1.5,\n    label=f'DESI 2024  w={w_desi}')\nax12.axhspan(\n    w_desi - w_desi_err,\n    w_desi + w_desi_err,\n    color=c_desi, alpha=0.35,\n    label=f'±{w_desi_err} band')\nax12.axhline(\n    -1.0, color='k',\n    ls=':', alpha=0.4,\n    label='ΛCDM')\nax12.invert_xaxis()\nax12.set_xlabel('redshift  z')\nax12.set_ylabel('w(z)')\nax12.set_title(\n    'TIFA  —  eqn of state  w(z)',\n    fontweight='bold')\nax12.set_ylim(-1.05, -0.5)\nax12.legend(fontsize=8)\nax12.grid(True, alpha=0.3)\n\n# ── Row 2: potentials ────────────────────\nax20 = fig.add_subplot(gs[2,0])\nax20.plot(r_sp_kpc, V_sp,\n          color=c_sp, lw=2)\nax20.set_xlabel('r  (kpc)')\nax20.set_ylabel('V(r)')\nax20.set_title('SP  —  potential V(r)',\n               fontweight='bold')\nax20.set_xlim(0, 8)\nax20.grid(True, alpha=0.3)\n\nax21 = fig.add_subplot(gs[2,1])\nax21.plot(r_gp_kpc, V_gp,\n          color=c_gp, lw=2)\nax21.set_xlabel('r  (kpc)')\nax21.set_ylabel('V(r)')\nax21.set_title('GP  —  potential V(r)',\n               fontweight='bold')\nax21.set_xlim(0, 8)\nax21.grid(True, alpha=0.3)\n\nax22 = fig.add_subplot(gs[2,2])\nax22.plot(z_tf, Omega_de,\n          color=c_tifa, lw=2,\n          label='Ω_DE(z)')\nax22.plot(z_tf, q_tf,\n          color='orange', lw=2,\n          ls='--', label='q(z)')\nax22.axhline(\n    0, color='k',\n    ls=':', alpha=0.4)\nax22.invert_xaxis()\nax22.set_xlabel('redshift  z')\nax22.set_title(\n    'TIFA  —  Ω_DE(z) & q(z)',\n    fontweight='bold')\nax22.legend(fontsize=8)\nax22.grid(True, alpha=0.3)\n\n# ── Row 3: SP vs GP overlay ──────────────\nax30 = fig.add_subplot(gs[3,0])\nax30.plot(r_sp_kpc, psi_sp,\n          color=c_sp, lw=2,\n          label='SP  ψ(r)')\nax30.plot(r_gp_kpc, psi_gp,\n          color=c_gp, lw=2,\n          ls='--', label='GP  ψ(r)')\nax30.set_xlabel('r  (kpc)')\nax30.set_ylabel('ψ(r)')\nax30.set_title(\n    'SP vs GP  —  wavefunction',\n    fontweight='bold')\nax30.set_xlim(0, 8)\nax30.legend(fontsize=9)\nax30.grid(True, alpha=0.3)\n\nax31 = fig.add_subplot(gs[3,1])\nax31.plot(r_sp_kpc, rho_sp_phys,\n          color=c_sp, lw=2,\n          label='SP  ρ(r)')\nax31.plot(r_gp_kpc, rho_gp_phys,\n          color=c_gp, lw=2,\n          ls='--', label='GP  ρ(r)')\nax31.set_xlabel('r  (kpc)')\nax31.set_ylabel(\n    r'ρ  ($10^7\\,M_\\odot\\,\\mathrm{kpc}^{-3}$)')\nax31.set_title(\n    'SP vs GP  —  density',\n    fontweight='bold')\nax31.set_xlim(0, 8)\nax31.legend(fontsize=9)\nax31.grid(True, alpha=0.3)\n\nax32 = fig.add_subplot(gs[3,2])\nax32.plot(r_sp_kpc, V_sp,\n          color=c_sp, lw=2,\n          label='SP  V(r)')\nax32.plot(r_gp_kpc, V_gp,\n          color=c_gp, lw=2,\n          ls='--', label='GP  V(r)')\nax32.set_xlabel('r  (kpc)')\nax32.set_ylabel('V(r)')\nax32.set_title(\n    'SP vs GP  —  potential',\n    fontweight='bold')\nax32.set_xlim(0, 8)\nax32.legend(fontsize=9)\nax32.grid(True, alpha=0.3)\n\n# ── super title ──────────────────────────\nfig.suptitle(\n    'TIFA Framework  —  '\n    'SP Soliton  |  GP Soliton  |  '\n    'Axion Dark Energy\\n'\n    f'SP: E={E_sp}   '\n    f'GP: E={E_gp}, g=0.1   '\n    f'TIFA: Λ⁴={Lambda4}, f={f}, '\n    f'φ₀/π=0.495   '\n    f'w(z=0)={w_tf[-1]:.4f}   '\n    f'DESI 2024: w=−0.90±0.05',\n    fontsize=11,\n    fontweight='bold'\n)\n\nplt.savefig(\n    'TIFA_comparison_v2.png',\n    dpi=150,\n    bbox_inches='tight')\nplt.show()\n\nprint(\"\\nTIFA COMPARISON SUMMARY v2\")\nprint(\"=\"*45)\nprint(f\"SP  soliton  E      = {E_sp}\")\nprint(f\"SP  rho peak        =\"\n      f\" {rho_sp_phys.max():.3e}\"\n      f\" M_sun/kpc^3\")\nprint(f\"GP  soliton  E      = {E_gp}\")\nprint(f\"GP  rho peak        =\"\n      f\" {rho_gp_phys.max():.3e}\"\n      f\" M_sun/kpc^3\")\nprint(f\"GP  core wider by   =\"\n      f\" {(x_gp[rho_gp<0.5*rho_gp.max()][0] - x_sp[rho_sp<0.5*rho_sp.max()][0]):.3f} kpc\")\nprint(f\"TIFA w(z=0)         =\"\n      f\" {w_tf[-1]:.4f}\")\nprint(f\"TIFA Omega_DE(z=0)  =\"\n      f\" {Omega_de[-1]:.4f}\")\nprint(f\"TIFA q(z=0)         =\"\n      f\" {q_tf[-1]:.4f}\")\nprint(f\"DESI 2024 band      =\"\n      f\" {w_desi}±{w_desi_err}\")\nin_band = (w_tf[-1] >= w_desi-w_desi_err\n           and w_tf[-1] <= w_desi+w_desi_err)\nprint(f\"TIFA inside band    = {in_band}\")\nprint(\"=\"*45)\nprint(\"TIFA_comparison_v2.png saved.\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-14T09:49:20.022360Z","iopub.execute_input":"2026-03-14T09:49:20.022678Z","iopub.status.idle":"2026-03-14T09:49:22.822425Z","shell.execute_reply.started":"2026-03-14T09:49:20.022654Z","shell.execute_reply":"2026-03-14T09:49:22.821458Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1800x1400 with 12 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"\nTIFA COMPARISON SUMMARY v2\n=============================================\nSP  soliton  E      = -0.693\nSP  rho peak        = 3.464e+06 M_sun/kpc^3\nGP  soliton  E      = -0.55\nGP  rho peak        = 3.419e+06 M_sun/kpc^3\nGP  core wider by   = 0.036 kpc\nTIFA w(z=0)         = -0.9959\nTIFA Omega_DE(z=0)  = 0.8941\nTIFA q(z=0)         = -0.8357\nDESI 2024 band      = -0.9±0.05\nTIFA inside band    = False\n=============================================\nTIFA_comparison_v2.png saved.\n","output_type":"stream"}],"execution_count":212},{"cell_type":"code","source":"import numpy as np\nfrom scipy.integrate import solve_ivp\nfrom scipy.integrate import trapezoid\nimport matplotlib.pyplot as plt\nfrom matplotlib.gridspec import GridSpec\n\n# ═══════════════════════════════════════════\n# SECTION 1 — SP SOLITON\n# ═══════════════════════════════════════════\n\nr_unit   = 1.0\nrho_unit = 1.0e7\n\ndef sp_rhs(x, y, E):\n    psi, dpsi, V, dV = y\n    if x < 1e-5:\n        d2psi = (V - E)*psi/3.0\n        d2V   = -psi**2/3.0\n    else:\n        d2psi = -(2/x)*dpsi + (V-E)*psi\n        d2V   = -(2/x)*dV  - psi**2\n    return [dpsi, d2psi, dV, d2V]\n\ndef shoot_sp(E, x_max=12.0, n=2000):\n    x  = np.linspace(1e-6, x_max, n)\n    y0 = [1.0, 0.0, 0.0, 0.0]\n    sol = solve_ivp(\n        lambda t,y: sp_rhs(t,y,E),\n        (x[0], x[-1]), y0,\n        t_eval=x, method='RK45',\n        rtol=1e-9, atol=1e-11)\n    return sol.t, sol.y[0], sol.y[2]\n\nE_sp = -0.693\nx_sp, psi_sp, V_sp = shoot_sp(E_sp)\nnorm    = np.sqrt(trapezoid(psi_sp**2, x_sp))\npsi_sp  = psi_sp / norm\nrho_sp  = psi_sp**2\nr_sp_kpc     = x_sp  * r_unit\nrho_sp_phys  = rho_sp * rho_unit\n\n# ═══════════════════════════════════════════\n# SECTION 2 — GP SOLITON\n# ═══════════════════════════════════════════\n\ndef gp_rhs(x, y, E, g=0.1):\n    psi, dpsi, V, dV = y\n    psi2 = psi**2\n    if x < 1e-5:\n        d2psi = (V + g*psi2 - E)*psi/3.0\n        d2V   = -psi2/3.0\n    else:\n        d2psi = (-(2/x)*dpsi\n                 + (V + g*psi2 - E)*psi)\n        d2V   = -(2/x)*dV - psi2\n    return [dpsi, d2psi, dV, d2V]\n\ndef shoot_gp(E, g=0.1,\n             x_max=12.0, n=2000):\n    x  = np.linspace(1e-6, x_max, n)\n    y0 = [1.0, 0.0, 0.0, 0.0]\n    sol = solve_ivp(\n        lambda t,y: gp_rhs(t,y,E,g),\n        (x[0], x[-1]), y0,\n        t_eval=x, method='RK45',\n        rtol=1e-9, atol=1e-11)\n    return sol.t, sol.y[0], sol.y[2]\n\nE_gp = -0.55\nx_gp, psi_gp, V_gp = shoot_gp(E_gp, g=0.1)\nnorm    = np.sqrt(trapezoid(psi_gp**2, x_gp))\npsi_gp  = psi_gp / norm\nrho_gp  = psi_gp**2\nr_gp_kpc     = x_gp  * r_unit\nrho_gp_phys  = rho_gp * rho_unit\n\n# ═══════════════════════════════════════════\n# SECTION 3 — TIFA AXION COSMOLOGY\n# ═══════════════════════════════════════════\n\nLambda4 = 1.316\nf       = 0.5\nOmega_m = 0.31\nOmega_r = 9.0e-5\nphi0    = 0.495 * np.pi\ndphi0   = 0.0\nt_start = np.log(0.01)\nt_end   = np.log(1.0)\n\n# observational constraints\nw_desi       = -0.90\nw_desi_err   =  0.05\nw_planck     = -1.03\nw_planck_err =  0.03\nw_boss       = -0.97\nw_boss_err   =  0.06\n\ndef tifa_rhs(t, y):\n    phi, dphi = y\n    V    = Lambda4*(1 - np.cos(phi/f))\n    dVdp = (Lambda4/f)*np.sin(phi/f)\n    a      = np.exp(t)\n    rho_m  = Omega_m * a**(-3)\n    rho_r  = Omega_r * a**(-4)\n    rho_de = 0.5*dphi**2 + V\n    rho    = rho_de + rho_m + rho_r\n    H      = np.sqrt(max(rho/3.0, 1e-30))\n    return [dphi, -3*H*dphi - dVdp]\n\nsol_tifa = solve_ivp(\n    tifa_rhs,\n    (t_start, t_end),\n    [phi0, dphi0],\n    method='RK45',\n    rtol=1e-9, atol=1e-11,\n    max_step=0.005)\n\nt_tf  = sol_tifa.t\nphi   = sol_tifa.y[0]\ndph   = sol_tifa.y[1]\na_tf  = np.exp(t_tf)\nz_tf  = 1.0/a_tf - 1.0\n\nV_tf     = Lambda4*(1 - np.cos(phi/f))\nKE_tf    = 0.5*dph**2\nrho_phi  = KE_tf + V_tf\nw_tf     = np.where(\n    rho_phi > 1e-30,\n    (KE_tf - V_tf)/rho_phi, -1.0)\nrho_m_tf = Omega_m * a_tf**(-3)\nrho_r_tf = Omega_r * a_tf**(-4)\nrho_tot  = rho_phi + rho_m_tf + rho_r_tf\nOmega_de = rho_phi / rho_tot\nq_tf     = 0.5*(1 + 3*w_tf*Omega_de)\n\n# ═══════════════════════════════════════════\n# SECTION 4 — FIGURE\n# ═══════════════════════════════════════════\n\nc_sp   = '#2166ac'\nc_gp   = '#d6604d'\nc_tifa = '#1a9850'\n\nfig = plt.figure(figsize=(18, 14))\ngs  = GridSpec(4, 3, figure=fig,\n               hspace=0.52,\n               wspace=0.35)\n\n# ── Row 0 ────────────────────────────────\nax00 = fig.add_subplot(gs[0,0])\nax00.plot(r_sp_kpc, psi_sp,\n          color=c_sp, lw=2)\nax00.set_xlabel('r  (kpc)')\nax00.set_ylabel('ψ(r)')\nax00.set_title('SP soliton  —  ψ(r)',\n               fontweight='bold')\nax00.set_xlim(0, 8)\nax00.grid(True, alpha=0.3)\n\nax01 = fig.add_subplot(gs[0,1])\nax01.plot(r_gp_kpc, psi_gp,\n          color=c_gp, lw=2)\nax01.set_xlabel('r  (kpc)')\nax01.set_ylabel('ψ(r)')\nax01.set_title('GP soliton  —  ψ(r)',\n               fontweight='