    "# Base values\n",
    "phi_ini_base  = 0.3908 * np.pi * f_E\n",
    "Om_base       = 0.315\n",
    "\n",
    "# Perturbation sizes (1-sigma physical priors)\n",
    "d_phi = 0.01 * phi_ini_base   # 1% variation in phi_ini\n",
    "d_Om  = 0.007                  # Planck 1-sigma on Omega_m\n",
    "\n",
    "def compute_S8(phi_ini, Omega_m0_val):\n",
    "    global Omega_m0, Omega_DE\n",
    "    Omega_m0 = Omega_m0_val\n",
    "    Omega_DE = 1.0 - Omega_m0 - Omega_r0\n",
    "\n",
    "    L4, sol_loc = find_Lambda4_thawing(phi_ini)\n",
    "\n",
    "    N_a   = np.linspace(np.log(1e-4), 0.0, 2000)\n",
    "    a_a   = np.exp(N_a)\n",
    "    H_a   = []\n",
    "    for N in N_a:\n",
    "        ph, dph = sol_loc.sol(N)\n",
    "        H2 = H_sq(np.exp(N), ph, dph)\n",
    "        H_a.append(np.sqrt(abs(H2)))\n",
    "    H_a   = np.array(H_a)\n",
    "    Hs    = H_a[::-1]\n",
    "    as_   = a_a[::-1]\n",
    "    Hi    = interp1d(as_, Hs,\n",
    "                     kind='cubic',\n",
    "                     fill_value='extrapolate')\n",
    "\n",
    "    def g_ode(a, y):\n",
    "        D, Dp = y\n",
    "        H  = Hi(a)\n",
    "        da = a * 1e-4\n",
    "        dH = (Hi(a+da) - Hi(a-da)) / (2*da)\n",
    "        Om = Omega_m0 / (a**3 * H**2)\n",
    "        c1 = -(3.0/a + dH/H)\n",
    "        c2 =  1.5 * Om / (a**2 * H**2)\n",
    "        return [Dp, c1*Dp + c2*D]\n",
    "\n",
    "    def H_L(a):\n",
    "        ODE = 1.0 - Omega_m0_val - Omega_r0\n",
    "        return np.sqrt(Omega_m0_val/a**3 + ODE)\n",
    "\n",
    "    def g_ode_L(a, y):\n",
    "        D, Dp = y\n",
    "        H  = H_L(a)\n",
    "        da = a * 1e-4\n",
    "        dH = (H_L(a+da) - H_L(a-da)) / (2*da)\n",
    "        Om = Omega_m0_val / (a**3 * H**2)\n",
    "        c1 = -(3.0/a + dH/H)\n",
    "        c2 =  1.5 * Om / (a**2 * H**2)\n",
    "        return [Dp, c1*Dp + c2*D]\n",
    "\n",
    "    a_ini = 1.0 / 51.0\n",
    "    aev   = np.linspace(a_ini, 1.0, 2000)\n",
    "\n",
    "    sT = solve_ivp(g_ode,   [a_ini,1.0],\n",
    "                   [a_ini,1.0], t_eval=aev,\n",
    "                   rtol=1e-8, atol=1e-10)\n",
    "    sL = solve_ivp(g_ode_L, [a_ini,1.0],\n",
    "                   [a_ini,1.0], t_eval=aev,\n",
    "                   rtol=1e-8, atol=1e-10)\n",
    "\n",
    "    DT = sT.y[0,-1]\n",
    "    DL = sL.y[0,-1]\n",
    "\n",
    "    s8_TIFA = 0.811 * (DT / DL)\n",
    "    S8      = s8_TIFA * np.sqrt(Omega_m0_val/0.3)\n",
    "    return S8\n",
    "\n",
    "# Base\n",
    "S8_base = compute_S8(phi_ini_base, Om_base)\n",
    "\n",
    "# Vary phi_ini\n",
    "S8_phi_p = compute_S8(phi_ini_base + d_phi, Om_base)\n",
    "S8_phi_m = compute_S8(phi_ini_base - d_phi, Om_base)\n",
    "dS8_phi  = (S8_phi_p - S8_phi_m) / 2.0\n",
    "\n",
    "# Vary Omega_m\n",
    "S8_Om_p  = compute_S8(phi_ini_base, Om_base + d_Om)\n",
    "S8_Om_m  = compute_S8(phi_ini_base, Om_base - d_Om)\n",
    "dS8_Om   = (S8_Om_p - S8_Om_m) / 2.0\n",
    "\n",
    "# Total error (add in quadrature)\n",
