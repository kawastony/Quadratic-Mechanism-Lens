) for N in N_a]\n        H_a = np.array(H_a)\n        Hi  = interp1d(a_a[::-1], H_a[::-1],\n                       kind='cubic',\n                       fill_value='extrapolate')\n\n        def g_ode(a, y):\n            D, Dp = y\n            H  = Hi(a)\n            da = a * 1e-4\n            dH = (Hi(a+da) - Hi(a-da)) / (2*da)\n            Om = Omega_m0 / (a**3 * H**2)\n            c1 = -(3.0/a + dH/H)\n            c2 =  1.5*Om / (a**2 * H**2)\n            return [Dp, c1*Dp + c2*D]\n\n        sT = solve_ivp(g_ode, [a_ini, 1.0],\n                       [a_ini, 1.0], t_eval=aev,\n                       rtol=1e-6, atol=1e-8)\n        DT = sT.y[0, -1]\n\n        ph0, dph0 = sol_loc.sol(0.0)\n        H2_0 = H_sq(1.0, ph0, dph0)\n        KE = 0.5 * H2_0 * dph0**2\n        PE = V(ph0)\n        w0 = (KE - PE) / (KE + PE)\n\n        s8T = 0.811 * (DT / DL_base)\n        S8  = s8T * np.sqrt(Omega_m0 / 0.3)\n\n        print(f\"{frac:>8.3f} {L4:>10.4f} \"\n              f\"{w0:>8.4f} {S8:>8.4f} \"\n              f\"{DT/DL_base:>8.4f}\")\n\n    except Exception as e:\n        print(f\"{frac:>8.3f}  failed: {e}\")\n        ","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-14T09:01:03.520456Z","iopub.execute_input":"2026-03-14T09:01:03.520669Z","iopub.status.idle":"2026-03-14T09:01:04.098961Z","shell.execute_reply.started":"2026-03-14T09:01:03.520651Z","shell.execute_reply":"2026-03-14T09:01:04.098061Z"}},"outputs":[{"name":"stdout","text":"  phi/pi         L4       w0       S8  D ratio\n------------------------------------------------\n   0.300     3.0224  -0.6518   0.8023   0.9655\n   0.340     1.8906  -0.7924   0.8148   0.9804\n   0.380     1.3843  -0.8583   0.8206   0.9874\n   0.391     1.2900  -0.8708   0.8217   0.9888\n   0.420     1.0875  -0.8978   0.8241   0.9916\n   0.460     0.8927  -0.9241   0.8264   0.9944\n","output_type":"stream"}],"execution_count":118},{"cell_type":"code","source":"# Cell 12 — S8 and w0 vs phi\n\nphi_fracs = [0.300, 0.340, 0.380,\n             0.391, 0.420, 0.460]\nw0_vals   = [-0.6518, -0.7924, -0.8583,\n             -0.8708, -0.8978, -0.9241]\nS8_vals   = [0.8023, 0.8148, 0.8206,\n             0.8217, 0.8241, 0.8264]\n\nfig, ax1 = plt.subplots(figsize=(8,5))\n\nax1.plot(phi_fracs, S8_vals,\n         'o-', color='royalblue',\n         lw=2, label=r'$S_8$ TIFA')\nax1.axhline(0.832, color='gray',\n            ls='--', lw=1,\n            label=r'Planck $S_8$=0.832')\nax1.axhline(0.766, color='orange',\n            ls='--', lw=1,\n            label=r'KiDS $S_8$=0.766')\nax1.fill_between(phi_fracs,\n                 0.832-0.013, 0.832+0.013,\n                 alpha=0.15, color='gray')\nax1.fill_between(phi_fracs,\n                 0.766-0.020, 0.766+0.020,\n                 alpha=0.15, color='orange')\nax1.set_xlabel(r'$\\phi_0 / \\pi$', fontsize=13)\nax1.set_ylabel(r'$S_8$', fontsize=13,\n               color='royalblue')\nax1.tick_params(axis='y',\n                labelcolor='royalblue')\n\nax2 = ax1.twinx()\nax2.plot(phi_fracs, w0_vals,\n         's--', color='crimson',\n         lw=2, label=r'$w_0$ TIFA')\nax2.axhline(-0.87, color='crimson',\n            ls=':', lw=1, alpha=0.5,\n            label=r'DESI $w_0$=-0.87')\nax2.fill_between(phi_fracs,\n                 -0.94, -0.80,\n                 alpha=0.08, color='crimson')\nax2.set_ylabel(r'$w_0$', fontsize=13,\n               color='crimson')\nax2.tick_params(axis='y',\n                labelcolor='crimson')\n\nlines1, labels1 = ax1.get_legend_handles_labels()\nlines2, labels2 = ax2.get_legend_handles_labels()\nax1.legend(lines1+lines2,\n           labels1+labels2,\n           fontsize=9, loc='center left')\n\nplt.title(r'TIFA parameter space: '\n          r'$S_8$ and $w_0$ vs $\\phi_0$',\n          fontsize=13)\nplt.tight_layout()\nplt.savefig('TIFA_parameter_space.png', dpi=150)\nplt.show()\nprint(\"Figure saved.\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-14T09:01:04.100086Z","iopub.execute_input":"2026