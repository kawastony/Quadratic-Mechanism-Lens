    "\n",
    "# rho_crit and rho_DM today\n",
    "rho_crit  = 3 * H0_eV**2 * M_Pl_eV**2\n",
    "rho_DM_0  = Omega_DM * rho_crit\n",
    "\n",
    "print(f\"rho_crit today  = {rho_crit:.4e} eV^4\")\n",
    "print(f\"rho_DM today    = {rho_DM_0:.4e} eV^4\")\n",
    "print()\n",
    "\n",
    "# z_osc from Cell 18\n",
    "z_osc = 2.697e6\n",
    "\n",
    "# Required rho at z_osc\n",
    "rho_at_osc = rho_DM_0 * (1 + z_osc)**3\n",
    "print(f\"z_osc           = {z_osc:.3e}\")\n",
    "print(f\"rho at z_osc    = {rho_at_osc:.4e} eV^4\")\n",
    "print()\n",
    "\n",
    "# Required phi_ini\n",
    "phi_ini_req = np.sqrt(2 * rho_at_osc) / m_fDM\n",
    "print(f\"Required phi_ini = {phi_ini_req:.4e} eV\")\n",
    "print(f\"phi_ini / M_Pl   = \"\n",
    "      f\"{phi_ini_req/M_Pl_eV:.4f}\")\n",
    "print()\n",
    "\n",
    "# Cross-check: propagate forward\n",
    "rho_check = 0.5 * m_fDM**2 * phi_ini_req**2\n",
    "rho_today_check = rho_check / (1+z_osc)**3\n",
    "Omega_check = rho_today_check / rho_crit\n",
    "print(f\"Cross-check:\")\n",
    "print(f\"rho(z_osc)      = {rho_check:.4e} eV^4\")\n",
