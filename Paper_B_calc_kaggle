    D, Dp = y\n            H  = Hi(a)\n            da = a * 1e-4\n            dH = (Hi(a+da)-Hi(a-da))/(2*da)\n            Om = Omega_m0/(a**3*H**2)\n            c1 = -(3.0/a + dH/H)\n            c2 =  1.5*Om/(a**2*H**2)\n            return [Dp, c1*Dp+c2*D]\n\n        def H_L(a):\n            return np.sqrt(Omega_m0/a**3+Omega_DE)\n\n        def g_L(a, y):\n            D, Dp = y\n            H  = H_L(a)\n            da = a * 1e-4\n            dH = (H_L(a+da)-H_L(a-da))/(2*da)\n            Om = Omega_m0/(a**3*H**2)\n            c1 = -(3.0/a + dH/H)\n            c2 =  1.5*Om/(a**2*H**2)\n            return [Dp, c1*Dp+c2*D]\n\n        a_ini = 1.0/51.0\n        aev   = np.linspace(a_ini, 1.0, 2000)\n        sT = solve_ivp(g_ode, [a_ini,1.0],\n                       [a_ini,1.0], t_eval=aev,\n                       rtol=1e-8, atol=1e-10)\n        sL = solve_ivp(g_L,   [a_ini,1.0],\n                       [a_ini,1.0], t_eval=aev,\n                       rtol=1e-8, atol=1e-10)\n\n        DT   = sT.y[0,-1]\n        DL   = sL.y[0,-1]\n        s8T  = 0.811 * (DT/DL)\n        S8   = s8T * np.sqrt(Omega_m0/0.3)\n\n        ph0, dph0 = sol_loc.sol(0.0)\n        H2_0 = H_sq(1.0, ph0, dph0)\n        KE   = 0.5*H2_0*dph0**2\n        PE   = V(ph0)\n        w0   = (KE-PE)/(KE+PE)\n\n        results.append({\n            'phi_frac': phi_ini/(np.pi*f_E),\n            'L4': L4,\n            'w0': w0,\n            'S8': S8,\n            'ratio': DT/DL\n        })\n    except Exception as e:\n        print(f\"  phi={phi_ini/(np.pi*f_E):.3f} failed: {e}\")\n\nprint(f\"{'phi/pi':>8} {'L4':>10} \"\n      f\"{'w0':>8} {'S8':>8} {'D ratio':>8}\")\nprint(\"-\" * 48)\nfor r in results:\n    print(f\"{r['phi_frac']:>8.3f} \"\n          f\"{r['L4']:>10.4f} \"\n          f\"{r['w0']:>8.4f} \"\n          f\"{r['S8']:>8.4f} \"\n          f\"{r['ratio']:>8.4f}\")\n          ","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-14T09:01:02.051382Z","iopub.execute_input":"2026-03-14T09:01