    "# Cell 13 — BAO distance ratios\n",
    "\n",
    "# BAO measures D_V(z)/r_drag\n",
    "# We check relative to LCDM\n",
    "# If ratio stays within 1%\n",
    "# BAO is safe\n",
    "\n",
    "from scipy.integrate import quad\n",
    "\n",
    "r_drag = 147.09  # Mpc, Planck 2018\n",
    "\n",
    "def chi(z_target, H_func):\n",
    "    integrand = lambda z: 1.0 / H_func(z)\n",
    "    result, _ = quad(integrand, 0, z_target)\n",
    "    return result  # in units of c/H0\n",
    "\n",
    "def DV(z_target, H_func):\n",
    "    c_val  = chi(z_target, H_func)\n",
    "    Hz     = H_func(z_target)\n",
    "    return (z_target * c_val**2 / Hz)**(1/3)\n",
    "\n",
    "# TIFA H(z) — rebuild from best fit\n",
    "Omega_m0 = 0.315\n",
    "Omega_DE = 1.0 - Omega_m0 - Omega_r0\n",
    "phi_ini  = 0.3908 * np.pi * f_E\n",
    "L4, sol  = find_Lambda4_thawing(phi_ini)\n",
    "Lambda4_global = L4\n",
    "\n",
    "N_b = np.linspace(np.log(1e-4), 0.0, 2000)\n",
    "a_b = np.exp(N_b)\n",
    "H_b = [np.sqrt(abs(H_sq(np.exp(N),\n",
    "       *sol.sol(N)))) for N in N_b]\n",
    "H_b = np.array(H_b)\n",
    "Hi_bao = interp1d(1.0/a_b[::-1] - 1.0,\n",
    "                  H_b[::-1],\n",
    "                  kind='cubic',\n",
    "                  fill_value='extrapolate',\n",
    "                  bounds_error=False)\n",
    "\n",
    "def H_TIFA_z(z):\n",
    "    return Hi_bao(z)\n",
    "\n",
    "def H_LCDM_z(z):\n",
    "    a = 1.0/(1.0+z)\n",
    "    return np.sqrt(Omega_m0/a**3 + Omega_DE)\n",
    "\n",
    "# BAO redshifts from DESI DR1\n",
    "z_bao = [0.295, 0.510, 0.706,\n",
    "         0.930, 1.317, 1.491, 2.330]\n",
