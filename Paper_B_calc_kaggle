nt()\nprint(f\"{'x':>8} {'rho/rho0':>12} \"\n      f\"{'Phi':>12}\")\nprint(\"-\"*35)\nfor sx in [0,0.5,1,1.5,2,3,5,8,12,15]:\n    rv = float(np.interp(sx,\n               x_raw, rho_norm))\n    pv = float(np.interp(sx,\n               x_raw, Phi_phys))\n    print(f\"{sx:>8.1f} {rv:>12.6f} \"\n          f\"{pv:>12.6f}\")\n\n# Soliton fit check\n# Known analytic form:\n# rho = rho0 / (1 + 0.091*(x/x_c)^2)^8\nprint()\nprint(\"Checking soliton fit quality:\")\nif x_c:\n    for sx in [0,0.5,1,1.5,2,3]:\n        rv  = float(np.interp(sx,\n                    x_raw, rho_norm))\n        sc  = sx / x_c\n        fit = 1.0/(1.0+0.091*sc**2)**8\n        print(f\"  x={sx:.1f}  \"\n              f\"numerical={rv:.4f}  \"\n              f\"fit={fit:.4f}\")\n\n# Plot\nfig, (ax1,ax2) = plt.subplots(\n    1,2,figsize=(12,4))\n\nax1.plot(x_raw, rho_norm, 'b-', lw=2,\n         label='numerical')\nif x_c:\n    xf  = np.linspace(0,10,200)\n    fit = 1.0/(1.0+0.091*(xf/x_c)**2)**8\n    ax1.plot(xf, fit, 'r--', lw=1.5,\n             label='analytic fit')\n    ax1.axvline(x_c, color='gray',\n                ls=':',\n                label=f'x_c={x_c:.2f}')\nax1.set_xlim(0,10)\nax1.set_ylim(0,1.1)\nax1.set_xlabel('x')\nax1.set_ylabel('ρ/ρ₀')\nax1.set_title('Soliton density profile')\nax1.legend()\nax1.grid(True, alpha=0.3)\n\nax2.plot(x_raw, Phi_phys, 'g-', lw=2)\nax2.set_xlim(0,15)\nax2.set_xlabel('x')\nax2.set_ylabel('Φ')\nax2.set_title('Gravitational potential')\nax2.grid(True, alpha=0.3)\n\nplt.tight_layout()\nplt.savefig('soliton_final2.png', dpi=150)\nplt.show()\nprint(\"Saved: soliton_final2.png\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-14T09:01:28.407967Z","iopub.execute_input":"2026-03-14T09:01:28.408210Z","iopub.status.idle":"2026-03-14T09:01:28.902934Z","shell.execute_reply.started":"2026-03-14T09:01:28.408188Z","shell.execute_reply":"2026-03-14T09:01:28.902027Z"}},"outputs":[{"name":"stdout","text":"alpha = 4.4330e+02\n∫u² dx = 1.000000\n\nrho(0) = 1.9652e+09\n\nCore radius error: f(a) and f(b) must have different signs\n\n       x     rho/rho0          Phi\n-----------------------------------\n     0.0     1.000000    -0.500000\n     0.5     0.000000    -0.500000\n     1.0     0.000000    -0.500000\n     1.5     0.000000    -0.500000\n     2.0     0.000000    -0.500001\n     3.0     0.000000    -0.500001\n     5.0     0.000000    -0.500003\n     8.0     0.000000    -0.500006\n    12.0     0.000000    -0.500009\n    15.0     0.000000    -0.500010\n\nChecking soliton fit quality:\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1200x400 with 2 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Saved: soliton_final2.png\n","output_type":"stream"}],"execution_count":138},{"cell_type":"code","source":"import numpy as np\nfrom scipy.integrate import solve_ivp, simpson\nfrom scipy.optimize import brentq\nimport matplotlib.pyplot as plt\nfrom dataclasses import dataclass\nfrom typing import Callable\n\n# ─────────────────────────────────────────\n# CORE DATA STRUCTURE\n# ─────────────────────────────────────────\n\n@dataclass\nclass FieldProfile:\n    \"\"\"\n    Universal profile for any\n    nonlinear eigenvalue problem.\n    Same structure across all fields.\n    \"\"\"\n    name    : str\n    x       : np.ndarray   # radial coord\n    psi     : np.ndarray   # wave function\n    V       : np.ndarray   # self-potential\n    E       : float        # eigenvalue\n    n_iter  : int          # iterations to converge\n    residual: float        # final residual\n\n# ─────────────────────────────────────────\n# PLUGGABLE PHYSICS\n# ─────────────────────────────────────────\n\nclass Physics:\n    \"\"\"\n    Override these methods to change\n    which field you are solving.\n    \"\"\"\n    name = \"base\"\n\n    def source(self, x, psi):\n        \"\"\"\n        What sources the potential.\n        SP/GP:    return psi**2\n        Hartree:  return psi**2 (same)\n        Gravity:  return psi**2 * x**2\n        \"\"\"\n        raise NotImplementedError\n\n    def coupling(self):\n        \"\"\"\n        Strength of back-reaction.\n        SP:      1.0\n        GP:      g (interaction strength)\n        Gravity: 8*pi*G\n        \"\"\"\n        raise NotImplementedError\n\n    def rhs(self, x, y, E):\n        \"\"\"\n        ODE right-hand side.\n        y = [psi, dpsi, V, dV]\n        \"\"\"\n        raise NotImplementedError\n\n\nclass SchrodingerPoisson(Physics):\n    \"\"\"\n    Fuzzy dark matter soliton.\n    -∇²ψ + V·ψ = E·ψ\n    ∇²V = -|ψ|²\n    \"\"\"\n    name = \"Schrodinger-Poisson (FDM)\"\n\n    def source(self, x, psi):\n        return psi**2\n\n    def coupling(self):\n        return 1.0\n\n    def rhs(self, x, y, E):\n        psi, dpsi, V, dV = (\n            float(v) for v in y)\n        if x < 1e-5:\n            d2psi = (V - E) * psi / 3.0\n            d2V   = -psi * psi / 3.0\n        else:\n            d2psi = (-(2/x)*dpsi\n                     + (V - E)*psi)\n            d2V   = (-(2/x)*dV\n                     - psi*psi)\n        return [dpsi, d2psi, dV, d2V]\n\n\nclass GrossPitaevskii(Physics):\n    \"\"\"\n    BEC soliton.\n    -∇²ψ + (V_trap + g|ψ|²)ψ = μ·ψ\n    Here V_trap = 0 (free soliton).\n    g is the interaction parameter.\n    Same skeleton as SP.\n    \"\"\"\n    name = \"Gross-Pitaevskii (BEC)\"\n\n    def __init__(self, g=-1.0):\n        # g < 0: attractive (soliton)\n        self.g = g\n\n    def source(self, x, psi):\n        return psi**2\n\n    def coupling(self):\n        return self.g\n\n    def rhs(self, x, y, E):\n        psi, dpsi, V, dV = (\n            float(v) for v in y)\n        g = self.g\n        # V here is g*|psi|^2 (mean field)\n        if x < 1e-5:\n            d2psi = (V - E) * psi / 3.0\n            d2V   = g * psi * psi / 3.0\n        else:\n            d2psi = (-(2/x)*dpsi\n                     + (V - E)*psi)\n            d2V   = (-(2/x)*dV\n                     + g*psi*psi)\n        return [dpsi, d2psi, dV, d2V]\n\n\nclass SemiclassGravity(Physics):\n    \"\"\"\n    Semiclassical gravity.\n    Schrodinger-Newton equation.\n    Same as SP but with\n    explicit Newton coupling.\n    -∇²ψ + m*Phi*ψ = E*ψ\n    ∇²Phi = 4*pi*G*m*|ψ|²\n    Dimensionless: same as SP.\n    \"\"\"\n    name = \"Schrodinger-Newton (Semiclass. Gravity)\"\n\n    def source(self, x, psi):\n        return psi**2\n\n    def coupling(self):\n        return 1.0   # absorbed in units\n\n    def rhs(self, x, y, E):\n        # Identical to SP in dim-less units\n        psi, dpsi, V, dV = (\n            float(v) for v in y)\n        if x < 1e-5:\n            d2psi = (V - E) * psi / 3.0\n            d2V   = -psi * psi / 3.0\n        else:\n            d2psi = (-(2/x)*dpsi\n                     + (V - E)*psi)\n            d2V   = (-(2/x)*dV\n                     - psi*psi)\n        return [dpsi, d2psi, dV, d2V]\n\n# ─────────────────────────────────────────\n# UNIVERSAL SOLVER\n# ─────────────────────────────────────────\n\ndef integrate_once(physics, E, V0,\n                   psi1=1.0,\n                   x_max=20.0):\n    \"\"\"\n    Single shooting integration.\n    Returns (x, psi, V, success).\n    \"\"\"\n    y0  = [0.0, psi1, V0, 0.0]\n    sol = solve_ivp(\n        physics.rhs,\n        (1e-5, x_max),\n        y0,\n        args=(E,),\n        method='RK45',\n        rtol=1e-7,\n        atol=1e-9,\n        max_step=0.05\n    )\n    return sol\n\n\ndef find_eigenvalue(physics, V0,\n                    E_range=(-2.0, -0.05),\n                    x_max=20.0,\n                    n_scan=60):\n    \"\"\"\n    Scan E, find ground state bracket,\n    refine with brentq.\n    Returns E_gs.\n    \"\"\"\n    E_vals = np.linspace(\n        E_range[0], E_range[1], n_scan)\n    u_ends = []\n\n    for E in E_vals:\n        sol = integrate_once(\n            physics, E, V0,\n            x_max=x_max)\n        if sol.success:\n            u_ends.append(\n                float(sol.y[0, -1]))\n        else:\n            u_ends.append(np.nan)\n\n    u_ends = np.array(u_ends)\n\n    # Find first sign change (ground state)\n    for i in range(len(E_vals)-1):\n        a, b = u_ends[i], u_ends[i+1]\n        if (not np.isnan(a) and\n            not np.isnan(b) and\n            a * b < 0):\n            E_gs = brentq(\n                lambda E: float(\n                    integrate_once(\n                        physics, E, V0,\n                        x_max=x_max\n                    ).y[0, -1]),\n                E_vals[i], E_vals[i+1],\n                xtol=1e-7\n            )\n            return E_gs\n\n    return None\n\n\ndef self_consistent_solve(\n        physics,\n        E_range=(-2.0, -0.05),\n        x_max=20.0,\n        max_iter=30,\n        tol=1e-5,\n        mix=0.5):\n    \"\"\"\n    Fixed-point iteration.\n    This is the universal skeleton.\n\n    Works for:\n    SP, GP, Hartree, Schrodinger-Newton.\n    Same loop, different physics.rhs.\n\n    mix: linear mixing parameter\n         0 < mix <= 1\n         smaller = more stable\n    \"\"\"\n    print(f\"\\n{'='*50}\")\n    print(f\"Solving: {physics.name}\")\n    print(f\"{'='*50}\")\n\n    # Step 1: initial guess for V0\n    V0 = E_range[0] * 0.5\n    print(f\"Initial V0 = {V0:.4f}\")\n\n    E_gs  = None\n    x_arr = None\n    V_arr = None\n    psi_arr = None\n\n    for iteration in range(max_iter):\n\n        # Step 2: find eigenvalue\n        E_new = find_eigenvalue(\n            physics, V0,\n            E_range=E_range,\n            x_max=x_max)\n\n        if E_new is None:\n            print(f\"  iter {iteration}: \"\n                  f\"no eigenvalue found\")\n            break\n\n        # Step 3: get full profile\n        sol = integrate_once(\n            physics, E_new, V0,\n            x_max=x_max)\n\n        x_new   = sol.t\n        psi_new = sol.y[0]\n        V_new   = sol.y[2]\n\n        # Step 4: normalize psi\n        I = simpson(psi_new**2, x=x_new)\n        if I > 0:\n            psi_new = psi_new / np.sqrt(I)\n\n        # Step 5: compute residual\n        if V_arr is not None:\n            V_interp = np.interp(\n                x_new, x_arr, V_arr)\n            residual = float(np.max(\n                np.abs(V_new - V_interp)))\n        else:\n            residual = np.inf\n\n        print(f\"  iter {iteration:2d}: \"\n              f\"E = {E_new:8.5f}  \"\n              f\"V0 = {V0:8.5f}  \"\n              f\"residual = {residual:.2e}\")\n\n        # Step 6: check convergence\n        if residual < tol:\n            print(f\"\\n  Converged in \"\n                  f\"{iteration+1} iterations\")\n            E_gs    = E_new\n            x_arr   = x_new\n            psi_arr = psi_new\n            V_arr   = V_new\n            break\n\n        # Step 7: mix old and new V\n        if V_arr is not None:\n            V_old_at_new = np.interp(\n                x_new, x_arr, V_arr)\n            V_mixed = ((1-mix)*V_old_at_new\n                       + mix*V_new)\n        else:\n            V_mixed = V_new\n\n        # Update for next iteration\n        V0    = float(V_mixed[0])\n        x_arr = x_new\n        V_arr = V_mixed\n        psi_arr = psi_new\n        E_gs    = E_new\n\n    # Build output profile\n    profile = FieldProfile(\n        name     = physics.name,\n        x        = x_arr,\n        psi      = psi_arr,\n        V        = V_arr,\n        E        = E_gs,\n        n_iter   = iteration + 1,\n        residual = residual\n    )\n    return profile\n\n\n# ─────────────────────────────────────────\n# RUN ALL THREE FIELDS\n# ─────────────────────────────────────────\n\nresults = {}\n\nfor phys in [SchrodingerPoisson(),\n             GrossPitaevskii(g=-1.0),\n             SemiclassGravity()]:\n    prof = self_consistent_solve(\n        phys,\n        E_range=(-2.0, -0.05),\n        x_max=15.0,\n        max_iter=25,\n        tol=1e-4,\n        mix=0.4\n    )\n    results[phys.name] = prof\n\n# ───────────────────────────