from scipy.integrate import solve_ivp\nimport matplotlib.pyplot as plt\nfrom matplotlib.gridspec import GridSpec\n\n# ═══════════════════════════════════════════\n# SECTION 1 — SP SOLITON\n# ═══════════════════════════════════════════\n\ndef sp_rhs(x, y, E):\n    psi, dpsi, V, dV = y\n    if x < 1e-5:\n        d2psi = (V - E)*psi/3.0\n        d2V   = -psi**2/3.0\n    else:\n        d2psi = -(2/x)*dpsi + (V-E)*psi\n        d2V   = -(2/x)*dV  - psi**2\n    return [dpsi, d2psi, dV, d2V]\n\ndef shoot_sp(E, x_max=12.0, n=2000):\n    x  = np.linspace(1e-6, x_max, n)\n    y0 = [1.0, 0.0, 0.0, 0.0]\n    sol = solve_ivp(\n        lambda t,y: sp_rhs(t,y,E),\n        (x[0], x[-1]), y0,\n        t_eval=x,\n        method='RK45',\n        rtol=1e-9, atol=1e-11\n    )\n    return sol.t, sol.y[0], sol.y[2]\n\n# SP ground state E ~ -0.693\nE_sp   = -0.693\nx_sp, psi_sp, V_sp = shoot_sp(E_sp)\n# Normalize\nnorm   = np.sqrt(np.trapz(psi_sp**2, x_sp))\npsi_sp = psi_sp / norm\nrho_sp = psi_sp**2\n\n# ═══════════════════════════════════════════\n# SECTION 2 — GP SOLITON\n# ═══════════════════════════════════════════\n\ndef gp_rhs(x, y, E, g=0.1):\n    psi, dpsi, V, dV = y\n    psi2 = psi**2\n    if x < 1e-5:\n        d2psi = (V + g*psi2 - E)*psi/3.0\n        d2V   = -psi2/3.0\n    else:\n        d2psi = (-(2/x)*dpsi\n                 + (V + g*psi2 - E)*psi)\n        d2V   = (-(2/x)*dV - psi2)\n    return [dpsi, d2psi, dV, d2V]\n\ndef shoot_gp(E, g=0.1, x_max=12.0,\n             n=2000):\n    x  = np.linspace(1e-6, x_max, n)\n    y0 = [1.0, 0.0, 0.0, 0.0]\n    sol = solve_ivp(\n        lambda t,y: gp_rhs(t,y,E,g),\n        (x[0], x[-1]), y0,\n        t_eval=x,\n        method='RK45',\n        rtol=1e-9, atol=1e-11\n    )\n    return sol.t, sol.y[0], sol.y[2]\n\n# GP ground state E ~ -0.55 (g=0.1)\nE_gp   = -0.55\nx_gp, psi_gp, V_gp = shoot_gp(E_gp,\n                                g=0.1)\nnorm   = np.sqrt(np.trapz(psi_gp**2,\n                           x_gp))\npsi_gp = psi_gp / norm\nrho