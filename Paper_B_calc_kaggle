    "        H2_0 = H_sq(1.0, ph0, dph0)\n",
    "        KE0  = 0.5 * H2_0 * dph0**2\n",
    "        PE0  = V(ph0)\n",
    "        rho0 = KE0 + PE0\n",
    "        w0   = (KE0 - PE0) / rho0\n",
    "\n",
    "        def H_ref(z):\n",
    "            a = 1.0/(1.0+z)\n",
    "            return np.sqrt(Omega_m0/a**3\n",
    "                           + rho0)\n",
    "\n",
    "        # BAO max deviation\n",
