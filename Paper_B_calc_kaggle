    "    try:\n",
    "        L4, sol_loc = find_Lambda4_thawing(phi_ini)\n",
    "        Lambda4_global = L4\n",
    "\n",
    "        # Build H(z)\n",
    "        N_s = np.linspace(np.log(1e-4), 0.0, 500)\n",
    "        a_s = np.exp(N_s)\n",
    "        H_s = [np.sqrt(abs(H_sq(np.exp(N),\n",
    "               *sol_loc.sol(N)))) for N in N_s]\n",
    "        H_s = np.array(H_s)\n",
    "        Hi_s = interp1d(1.0/a_s[::-1]-1.0,\n",
    "                        H_s[::-1],\n",
    "                        kind='cubic',\n",
    "                        fill_value='extrapolate',\n",
    "                        bounds_error=False)\n",
    "\n",
    "        # rho_phi today\n",
