    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# ─────────────────────────────────────\n",
    "# TIFA EFT Loop Check\n",
    "# Coleman-Weinberg one-loop correction\n",
    "# Stage 1 of QG roadmap\n",
    "# ─────────────────────────────────────\n",
    "\n",
    "# fiducial parameters\n",
    "Lambda4 = 1.316\n",
    "f       = 0.500\n",
    "mu2     = 1.0   # renormalization scale\n",
    "\n",
    "# field values along ridge\n",
    "phi_over_pi = np.linspace(0.30, 0.70, 500)\n",
    "phi = phi_over_pi * np.pi * f\n",
    "\n",
    "# tree-level potential\n",
    "V_tree = Lambda4 * (1 - np.cos(phi / f))\n",
    "\n",
    "# field-dependent mass squared\n",
    "# m²(φ) = d²V/dφ² = (Λ⁴/f²)cos(φ/f)\n",
    "m2_phi = (Lambda4 / f**2) * np.cos(phi / f)\n",
    "\n",
    "# one-loop CW correction\n",
    "# only where m² > 0 (stable region)\n",
    "# near top of potential m² < 0\n",
    "# we handle both cases\n",
    "m2_abs = np.abs(m2_phi)\n",
    "log_term = np.log(m2_abs / mu2 + 1e-30)\n",
    "\n",
    "DeltaV_CW = (m2_abs**2 / (64 * np.pi**2)) \\\n",
    "            * (log_term - 1.5)\n",
    "\n",
    "# fractional correction\n",
    "# avoid division by zero near φ=0\n",
    "V_safe = np.where(\n",
    "    np.abs(V_tree) > 1e-10,\n",
    "    V_tree,\n",
    "    1e-10)\n",
    "\n",
    "frac_correction = np.abs(DeltaV_CW / V_safe)\n",
    "\n",
    "# ─────────────────────────────────────\n",
    "# EFT validity: f < M_Pl check\n",
    "# in natural units M_Pl = 1\n",
    "M_Pl = 1.0\n",
    "print(\"=\" * 45)\n",
    "print(\"TIFA EFT Validity Checks\")\n",
    "print(\"=\" * 45)\n",
    "print(f\"f = {f:.3f} M_Pl\")\n",
    "print(f\"f < M_Pl: {f < M_Pl}\")\n",
    "print(f\"Axion EFT valid: {f < M_Pl}\")\n",
    "print()\n",
    "\n",
    "# field excursion along ridge\n",
    "phi_ini = 0.495 * np.pi * f\n",
    "phi_fin = 0.000\n",
    "Delta_phi = np.abs(phi_ini - phi_fin)\n",
    "print(f\"Field excursion Δφ = {Delta_phi:.4f}\")\n",
    "print(f\"Δφ / M_Pl = {Delta_phi / M_Pl:.4f}\")\n",
    "print(f\"Sub-Planckian: {Delta_phi < M_Pl}\")\n",
    "print()\n",
    "\n",
    "# fractional correction at fiducial\n",
    "idx_fid = np.argmin(\n",
    "    np.abs(phi_over_pi - 0.495))\n",
    "frac_fid = frac_correction[idx_fid]\n",
    "print(f\"ΔV/V at fiducial φ₀ = {frac_fid:.2e}\")\n",
    "print(f\"Radiatively stable: \"\n",
    "      f\"{frac_fid < 0.01}\")\n",
    "print()\n",
    "\n",
    "# max correction across ridge window\n",
    "idx_window = (phi_over_pi >= 0.45) & \\\n",
    "             (phi_over_pi <= 0.55)\n",
    "frac_max = np.max(\n",
    "    frac_correction[idx_window])\n",
    "print(f\"Max ΔV/V in DESI window: \"\n",
    "      f\"{frac_max:.2e}\")\n",
    "print(f\"Ridge radiatively stable: \"\n",
    "      f\"{frac_max < 0.01}\")\n",
    "print(\"=\" * 45)\n",
    "\n",
    "# ─────────────────────────────────────\n",
    "# Plot\n",
    "fig, axes = plt.subplots(\n",
    "    1, 2, figsize=(12, 5))\n",
    "fig.suptitle(\n",
    "    \"TIFA Stage 1 — EFT Loop Check\\n\"\n",
    "    \"Coleman-Weinberg Radiative Stability\",\n",
    "    fontsize=13, fontweight='bold')\n",
    "\n",
    "# left: fractional correction\n",
    "ax = axes[0]\n",
    "ax.semilogy(\n",
    "    phi_over_pi,\n",
    "    frac_correction,\n",
    "    'b-', lw=2)\n",
    "ax.axvspan(0.45, 0.55,\n",
    "    alpha=0.15, color='salmon',\n",
    "    label='DESI window')\n",
    "ax.axhline(0.01,\n",
    "    color='red', ls='--',\n",
    "    label='1% threshold')\n",
    "ax.axvline(0.495,\n",
    "    color='green', ls=':',\n",
    "    label=f'fiducial φ₀')\n",
    "ax.set_xlabel(r'$\\varphi_0 / \\pi$',\n",
    "    fontsize=12)\n",
    "ax.set_ylabel(r'$|\\Delta V / V|$',\n",
    "    fontsize=12)\n",
    "ax.set_title(\n",
    "    'One-loop fractional correction',\n",
    "    fontsize=11)\n",
    "ax.legend(fontsize=9)\n",
    "ax.grid(True, alpha=0.3)\n",
    "\n",
    "# right: tree vs loop potential\n",
    "ax2 = axes[1]\n",
    "ax2.plot(phi_over_pi, V_tree,\n",
    "    'b-', lw=2, label='Tree level $V$')\n",
    "ax2.plot(phi_over_pi,\n",
    "    V_tree + DeltaV_CW,\n",
    "    'r--', lw=2,\n",
    "    label='$V + \\Delta V_{CW}$')\n",
    "ax2.axvspan(0.45, 0.55,\n",
    "    alpha=0.15, color='salmon',\n",
    "    label='DESI window')\n",
    "ax2.set_xlabel(r'$\\varphi_0 / \\pi$',\n",
    "    fontsize=12)\n",
    "ax2.set_ylabel('$V$', fontsize=12)\n",
    "ax2.set_title(\n",
    "    'Tree vs one-loop potential',\n",
    "    fontsize=11)\n",
    "ax2.legend(fontsize=9)\n",
    "ax2.grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(\n",
    "    '/kaggle/working/'\n",
    "    'TIFA_fig7_EFT_loop_check.png',\n",
    "    dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"Saved: TIFA_fig7_EFT_loop_check.png\")\n"
   ]
