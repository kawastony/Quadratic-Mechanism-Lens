.loglog(z_bbn, Omega_DE_z,\n    'b-', lw=2, label=r'$\\Omega_{DE}(z)$')\nax4.axhline(0.01, color='red',\n    ls='--', lw=1.5,\n    label='BBN limit 0.01')\nax4.axhline(0.001, color='orange',\n    ls='--', lw=1.5,\n    label='Conservative 0.001')\nax4.axvline(z_recomb, color='gray',\n    ls=':', label='Recombination')\nax4.axvline(3e8, color='purple',\n    ls=':', label='BBN')\nax4.set_xlabel('Redshift z', fontsize=11)\nax4.set_ylabel(r'$\\Omega_{DE}(z)$',\n    fontsize=11)\nax4.set_title('F1 — Early Universe Safety\\n'\n    r'$\\Omega_{DE}$ back to BBN',\n    fontsize=11)\nax4.legend(fontsize=8)\nax4.grid(True, alpha=0.3)\n\n# F2 — growth and f*sigma8\nax5 = axes[1,1]\nax5_twin = ax5.twinx()\nax5.plot(z_growth, D_tifa, 'b-',\n    lw=2, label='D(z) TIFA')\nax5.plot(z_growth, D_lcdm, 'r--',\n    lw=2, label='D(z) ΛCDM')\nax5_twin.plot(z_growth, fsig8_tifa,\n    'b:', lw=2, label=r'$f\\sigma_8$ TIFA')\nax5_twin.plot(z_growth, fsig8_lcdm,\n    'r-.', lw=2, label=r'$f\\sigma_8$ ΛCDM')\nax5.set_xlim(0, 3)\nax5.set_xlabel('Redshift z', fontsize=11)\nax5.set_ylabel('Growth factor D(z)',\n    fontsize=11)\nax5_twin.set_ylabel(r'$f\\sigma_8(z)$',\n    fontsize=11)\nax5.set_title('F2 — Linear Growth\\n'\n    r'$D(z)$ and $f\\sigma_8(z)$',\n    fontsize=11)\nlines1, labs1 = ax5.get_legend_handles_labels()\nlines2, labs2 = ax5_twin.get_legend_handles_labels()\nax5.legend(lines1+lines2,\n    labs1+labs2, fontsize=8)\nax5.grid(True, alpha=0.3)\n\n# F3 — ridge power law\nax6 = axes[1,2]\nax6.scatter(f_ridge, Lambda4_f,\n    color='blue', s=40, zorder=5,\n    label='Ridge points')\nax6.plot(f_ridge, Lambda4_fit,\n    'r-', lw=2,\n    label=f'Fit: Λ⁴={A_fit:.3f}×f^{n_fit:.3f}\\n'\n          f'R²={r_squared:.4f}')\nax6.axvline(0.5, color='green',\n    ls=':', label='fiducial f=0.5')\nax6.set_xlabel('f / M_Pl', fontsize=11)\nax6.set_ylabel(r'$\\Lambda^4$', fontsize=11)\nax6.set_title('F3 — Ridge Power Law\\n'\n    r'$\\Lambda^4 \\propto f^n$',\n    fontsize=11)\nax6.legend(fontsize=8)\nax6.grid(True, alpha=0.3)\n\nplt.tight_layout()\nplt.savefig(\n    '/kaggle/working/'\n    'TIFA_fig10_full_diagnostics.png',\n    dpi=150, bbox_inches='tight')\nplt.show()\nprint(\"Saved: TIFA_fig10_full_diagnostics.png\")\n\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-14T13:18:29.358029Z","iopub.execute_input":"2026-03-14T13:18:29.358968Z","iopub.status.idle":"2026-03-14T13:18:34.781433Z","shell.execute_reply.started":"2026-03-14T13:18:29.358926Z","shell.execute_reply":"2026-03-14T13:18:34.780038Z"}},"outputs":[{"name":"stdout","text":"============================================================\nTIFA Full Diagnostic Block E1-F3\n============================================================\n\nCELL E1 — Quantified Swampland Margins\n------------------------------------------------------------\nSlope |∇V|/V across full ridge:\n  min    = 1.1287\n  median = 2.0317\n  max    = 3.3861\n\n  c = 0.1:\n    satisfied: 100.0% of ridge\n    margin min:    1.0287\n    margin median: 1.9317\n    margin max:    3.2861\n\n  c = 0.3:\n    satisfied: 100.0% of ridge\n    margin min:    0.8287\n    margin median: 1.7317\n    margin max:    3.0861\n\n  c = 1.0:\n    satisfied: 100.0% of ridge\n    margin min:    0.1287\n    margin median: 1.0317\n    margin max:    2.3861\n\nCELL E2 — Envelope Plots\n------------------------------------------------------------\nw(z=0) envelope across phi0 ridge:\n  min    = 0.7556\n  median = 0.8894\n  max    = 0.9662\n  all within DESI [-0.95,-0.85]: False\n\nCELL E3 — Failure Map\n------------------------------------------------------------\nGrid points passing DESI band: 0 / 1600\nGrid points passing c=0.1 slope: 1600 / 1600\nGrid points passing both: 0 / 1600\nGrid points failing both: 0 / 1600\n\nCELL F1 — Omega_DE(z) BBN Safety\n------------------------------------------------------------\n  today       Ω_DE = 2.173e-01  safe (<0.01): False\n  z=1         Ω_DE = 2.173e-01  safe (<0.01): False\n  z=10        Ω_DE = 1