re size 1800x1100 with 7 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"Saved: TIFA_fig10_full_diagnostics.png\n","output_type":"stream"}],"execution_count":14},{"cell_type":"code","source":"import numpy as np\nimport matplotlib.pyplot as plt\nfrom scipy.integrate import solve_ivp\nfrom scipy.optimize import minimize_scalar\n\n# ═══════════════════════════════════════════\n# TIFA Verification + Fix Block\n# E1v: Slope verification — settle the number\n# E3f: E3 bug fix — proper DESI filter\n# G1:  Statistical comparison Δχ² AIC vs ΛCDM\n# ═══════════════════════════════════════════\n\nLambda4  = 1.316\nf        = 0.500\nM_Pl     = 1.0\nOmega_m  = 0.310\nOmega_de = 0.689\nOmega_r  = 9.0e-5\nH0       = 1.0\nsigma8_planck = 0.811\n\n# ───────────────────────────────────────────\n# CELL E1v — Slope Verification\n# Settle min/median/max once and for all\n# Print every step transparently\n# ───────────────────────────────────────────\nprint(\"=\" * 60)\nprint(\"CELL E1v — Slope Verification\")\nprint(\"Settling |∇V|/V across ridge\")\nprint(\"=\" * 60)\nprint()\n\ndef V_tifa(phi, f_val, L4):\n    return L4 * (1 - np.cos(phi / f_val))\n\ndef dV_tifa(phi, f_val, L4):\n    return (L4 / f_val) * np.sin(phi / f_val)\n\ndef slope(phi, f_val, L4):\n    V  = V_tifa(phi, f_val, L4)\n    dV = dV_tifa(phi, f_val, L4)\n    if abs(V) < 1e-10:\n        return 0.0\n    return abs(dV) / abs(V)\n\n# three ridge scans — explicit and transparent\nprint(\"Scan 1: phi0/pi from 0.45 to 0.55\")\nprint(\"        f=0.5, Lambda4=1.316\")\nphi_scan = np.linspace(0.45, 0.55, 100)\nsl_phi   = np.array([\n    slope(p * np.pi * f, f, Lambda4)\n    for p in phi_scan])\nprint(f\"  min    = {np.min(sl_phi):.6f}\")\nprint(f\"  median = {np.median(sl_phi):.6f}\")\nprint(f\"  max    = {np.max(sl_phi):.6f}\")\nprint()\n\nprint(\"Scan 2: f from 0.3 to 0.9\")\nprint(\"        phi0=0.495*pi*f, Lambda4 on ridge\")\nf_scan  = np.linspace(0.3, 0.9, 100)\nL4_scan = 1.0 + 0.6 * (f_scan - 0.3)\nsl_f    = np.array([\n    slope(0.495 * np.pi * fi, fi, L4i)\n    for fi, L4i in zip(f_scan, L4_scan)])\nprint(f\"  min    = {np.min(sl_f):.6f}\")\nprint(f\"  median = {np.median(sl_f):.6f}\")\nprint(f\"  max    = {np.max(sl_f):.6f}\")\nprint()\n\nprint(\"Scan 3: Lambda4 from 1.1 to 1.5\")\nprint(\"        phi0=0.495*pi*f, f=0.5\")\nL4_scan2 = np.linspace(1.1, 1.5, 100)\nsl_L4    = np.array([\n    slope(0.495 * np.pi * f, f, L4i)\n    for L4i in L4_scan2])\nprint(f\"  min    = {np.min(sl_L4):.6f}\")\nprint(f\"  median = {np.median(sl_L4):.6f}\")\nprint(f\"  max    = {np.max(sl_L4):.6f}\")\nprint()\n\nall_slopes = np.concatenate([sl_phi,\n                              sl_f, sl_L4])\nprint(\"Combined ridge:\")\nprint(f\"  min    = {np.min(all_slopes):.6f}\")\nprint(f\"  median = {np.median(all_slopes):.6f}\")\nprint(f\"  max    = {np.max(all_slopes):.6f}\")\nprint()\n\n# verdict on c values\nfor c in [0.1, 0.3, 1.0]:\n    n_sat = np.sum(all_slopes >= c)\n    pct   = 100 * n_sat / len(all_slopes)\n    above = all_slopes[all_slopes >= c]\n    if len(above) > 0:\n        print(f\"c = {c:.1f}: {pct:.1f}% satisfied  \"\n              f\"margin [{np.min(above-c):.4f}, \"\n              f\"{np.max(above-c):.4f}]\")\n    else:\n        deficit = c - all_slopes\n        print(f\"c = {c:.1f}: 0.0% satisfied  \"\n              f\"deficit [{np.min(deficit):.4f}, \"\n              f\"{np.max(deficit):.4f}]\")\n\nprint()\nprint(\"VERDICT:\")\nif np.max(all_slopes) >= 1.0:\n    print(\"  Max slope >= 1.0\")\n    print(\"  Strong dS bound satisfied\")\n    print(\"  somewhere on ridge\")\nelif np.max(all_slopes) >= 0.1:\n    print(\"  Max slope >= 0.1\")\n    print(\"  Weak bound satisfied\")\n    print(\"  Strong bound not satisfied\")\n    print(\"  This is the honest result\")\nelse:\n    print(\"  No c value satisfied\")\n    print(\"  Slow-roll regime confirmed\")\n\n# ───────────────────────────────────────────\n# CELL E3f — E3 Bug Fix\n# Proper point-by-point DESI filter\n# Using solved w(z=0) not slow-roll approx\n# ───────────────────────────────────────────\nprint()\nprint(\"=\" * 60)\nprint(\"CELL E3f — Failure Map Bug Fix\")\nprint(\"Proper DESI filter on solved w(z=0)\")\nprint(\"=\" * 60)\nprint()\n\ndef solve_w0(phi_ini, f_val, L4_val):\n    \"\"\"Solve TIFA and return w(z=0).\"\"\"\n    def eom(N, y):\n        phi_v, dphi = y\n        rho_m = Omega_m * H0**2 * np.exp(-3*N)\n        V_v   = L4_val*(1-np.cos(phi_v/f_val))\n        KE    = 0.5 * dphi**2\n        rho   = KE + V_v + rho_m\n        H2    = max(rho / 3, 1e-30)\n        dV_v  = (L4_val/f_val)*np.sin(phi_v/f_val)\n        ddphi = -3*dphi - dV_v/H2\n        return [dphi, ddphi]\n    try:\n        sol = solve_ivp(eom, (-7, 0),\n                        [phi_ini, 0.0],\n                        method='Radau',\n                        rtol=1e-6, atol=1e-8,\n                        dense_output=False)\n        if not sol.success:\n            return None\n        phi_f  = sol.y[0][-1]\n        dphi_f = sol.y[1][-1]\n        V_f    = L4_val*(1-np.cos(phi_f/f_val))\n        KE_f   = 0.5*dphi_f**2\n        denom  = KE_f + V_f\n        if denom < 1e-10:\n            return None\n        return (KE_f - V_f) / denom\n    except Exception:\n        return None\n\n# coarser grid for speed — 20x20\nf_grid  = np.linspace(0.2, 1.0, 20)\nL4_grid = np.linspace(0.5, 2.5, 20)\n\nw0_solved  = np.full((20, 20), np.nan)\nslope_grid = np.zeros((20, 20))\n\nprint(\"Solving w(z=0) on 20x20 grid...\")\nfor i, L4i in enumerate(L4_grid):\n    for j, fi in enumerate(f_grid):\n        phi_i = 0.495 * np.pi * fi\n        w0_solved[i,j]  = solve_w0(\n            phi_i, fi, L4i) or np.nan\n        slope_grid[i,j] = slope(\n            phi_i, fi, L4i)\n\n# proper DESI filter\ndesi_lo, desi_hi = -0.95, -0.85\nin_desi  = ((w0_solved >= desi_lo) &\n            (w0_solved <= desi_hi))\npass_c01 = slope_grid >= 0.1\npass_both = in_desi & pass_c01\nvalid     = ~np.isnan(w0_solved)\n\nprint(f\"Valid grid points: \"\n 