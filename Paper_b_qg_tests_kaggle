tol=1e-6, atol=1e-8)\n\nprint(\"Running LQC TIFA...\")\nsol_lqc = solve_ivp(\n    tifa_lqc_safe,\n    (N_ini, N_fin), y0,\n    t_eval=N_eval,\n    method='Radau',          # stiff solver\n    rtol=1e-6, atol=1e-8)\n\nprint(f\"Standard solver success: {sol_std.success}\")\nprint(f\"LQC solver success:      {sol_lqc.success}\")\n\n# compute w(N)\ndef compute_w(sol):\n    w_arr = []\n    for i in range(len(sol.t)):\n        phi_i  = sol.y[0][i]\n        dphi_i = sol.y[1][i]\n        V_i    = Lambda4 * (1 - np.cos(phi_i / f))\n        KE_i   = 0.5 * dphi_i**2\n        denom  = KE_i + V_i\n        w_i    = (KE_i - V_i) / denom if denom > 1e-10 else -1.0\n        w_arr.append(w_i)\n    return np.array(w_arr)\n\nw_std = compute_w(sol_std)\nw_lqc = compute_w(sol_lqc)\n\nw0_std = w_std[-1]\nw0_lqc = w_lqc[-1]\ndelta_w = abs(w0_lqc - w0_std)\n\ndesi_lo = -0.95\ndesi_hi = -0.85\n\nprint()\nprint(\"=\" * 50)\nprint(\"TEST B RESULTS\")\nprint(\"=\" * 50)\nprint(f\"Standard  w(z=0) = {w0_std:.4f}\")\nprint(f\"LQC       w(z=0) = {w0_lqc:.4f}\")\nprint(f\"Shift     Δw     = {delta_w:.6f}\")\nprint(f\"Standard in DESI band: \"\n      f\"{desi_lo <= w0_std <= desi_hi}\")\nprint(f\"LQC      in DESI band: \"\n      f\"{desi_lo <= w0_lqc <= desi_hi}\")\nprint(f\"Attractor survives LQC: \"\n      f\"{delta_w < 0.05}\")\nprint(\"=\" * 50)\n\n# plot\nz_std = np.exp(-sol_std.t) - 1\nz_lqc = np.exp(-sol_lqc.t) - 1\n\nfig, ax = plt.subplots(figsize=(8, 5))\nax.plot(z_std, w_std, 'b-', lw=2,\n    label=f'Standard  w(z=0) = {w0_std:.4f}')\nax.plot(z_lqc, w_lqc, 'r--', lw=2,\n    label=f'LQC       w(z=0) = {w0_lqc:.4f}')\nax.axhspan(desi_lo, desi_hi,\n    alpha=0.15, color='salmon',\n    label='DESI 1σ band')\nax.axhline(-1.0, color='gray',\n    ls=':', lw=1, label='ΛCDM')\nax.set_xlim(0, 3)\nax.set_ylim(-1.05, -0.70)\nax.set_xlabel('Redshift z', fontsize=12)\nax.set_ylabel('w(z)', fontsize=12)\nax.set_title(\n    'TIFA Test B — LQC Bounce\\n'\n    'Standard vs LQC Modified Friedmann',\n    font