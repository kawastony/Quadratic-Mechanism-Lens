nd < a_start * M_Pl\n# Applied to dark energy field modes\n# NOT inflation — we state this clearly\n# ───────────────────────────────────────────\nprint(\"=\" * 55)\nprint(\"CELL D1 — TCC Proper\")\nprint(\"Trans-Planckian Censorship Check\")\nprint(\"=\" * 55)\nprint()\nprint(\"Assumptions stated explicitly:\")\nprint(\"  - Applied to DE field evolution\")\nprint(\"    NOT inflationary TCC\")\nprint(\"  - Scale factor normalized a(z=0) = 1\")\nprint(\"  - Pivot scale k* = 0.05 Mpc^-1\")\nprint(\"  - H in units of H0 = 1\")\nprint(\"  - M_Pl = 1 (reduced Planck mass)\")\nprint()\n\n# TCC condition for DE:\n# physical wavelength of DE mode\n# must not have been sub-Planckian\n# at any point during evolution\n#\n# lambda_phys(z) = lambda_comoving / a(z)\n#                = (2π / k*) * (1/(1+z))\n#\n# Planck length: l_Pl = 1/M_Pl = 1\n#\n# TCC safe if:\n# lambda_phys(z) > l_Pl for all z\n# i.e. k* / (a(z) * M_Pl) < 1\n\n# pivot scale in H0 units\n# k* = 0.05 Mpc^-1\n# H0 = 100 h km/s/Mpc ~ 1/3000 Mpc^-1\n# k* / H0 ~ 0.05 * 3000 ~ 150\nk_star_over_H0 = 150.0\n\n# physical momentum at redshift z\nz_arr = np.linspace(0, 1100, 10000)\na_arr = 1.0 / (1 + z_arr)\n\n# H(z) for background ΛCDM\nH_arr = H0 * np.sqrt(\n    Omega_m * (1 + z_arr)**3 + Omega_de)\n\n# physical wavenumber\nk_phys_arr = k_star_over_H0 * (1 + z_arr)\n\n# TCC ratio: k_phys / (a * M_Pl * H)\n# safe if < 1\n# we normalize to Hubble units\n# k_phys / H gives dimensionless ratio\ntcc_ratio = k_star_over_H0 / H_arr\n\nprint(f\"Pivot scale k* = 0.05 Mpc⁻¹\")\nprint(f\"k* / H0 = {k_star_over_H0:.1f}\")\nprint()\nprint(f\"TCC ratio k*/H(z) at key redshifts:\")\nfor z_check in [0, 0.5, 1.0, 2.0, 10.0,\n                100.0, 1000.0]:\n    idx = np.argmin(np.abs(z_arr - z_check))\n    print(f\"  z = {z_check:6.1f}  \"\n          f\"k*/H = {tcc_ratio[idx]:.4f}  \"\n          f\"sub-Hubble: \"\n          f\"{tcc_ratio[idx] < 1.0}\")\n\nprint()\nprint(\"Note: TCC for DE modes asks whether\")\nprint(\"the pivot scale