--------------------------\nComoving mode at z=1: k = 3.1496\nPhysical momentum today: k_phys = 3.1496\nSub-Planckian: False\n\n==================================================\nSummary\n==================================================\nAll three swampland-motivated\nconsistency checks are satisfied\nat the fiducial point and across\nthe DESI-consistent ridge.\n\nThese are heuristic checks, not\nproofs. They establish that TIFA\noperates in a regime compatible\nwith swampland expectations.\n==================================================\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1200x500 with 2 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"\nSaved: TIFA_fig8_swampland_checks.png\n","output_type":"stream"}],"execution_count":7},{"cell_type":"code","source":"import numpy as np\nimport matplotlib.pyplot as plt\nfrom scipy.integrate import solve_ivp\n\n# ═══════════════════════════════════════════\n# TIFA §5.2 — String/LQC Extension\n# Three Sequential Tests\n# A: Instanton Action\n# B: LQC Bounce\n# C: Moduli / CY Volume\n# ═══════════════════════════════════════════\n\n# fiducial parameters\nLambda4  = 1.316\nf        = 0.500\nM_Pl     = 1.0\nphi0     = 0.495 * np.pi * f\nOmega_m  = 0.31\nOmega_de = 0.689\nH0       = 1.0\n\nprint(\"=\" * 55)\nprint(\"TIFA §5.2 String/LQC Extension\")\nprint(\"Three Sequential UV/QG Tests\")\nprint(\"=\" * 55)\n\n# ───────────────────────────────────────────\n# TEST A — Instanton Action\n# Λ⁴ ~ M_Pl⁴ exp(-S_inst)\n# solve for S_inst given Λ⁴ = 1.316\n# in units where M_Pl = 1\n# ───────────────────────────────────────────\nprint()\nprint(\"TEST A — Instanton Action Check\")\nprint(\"-\" * 55)\n\n# Λ⁴ = M_Pl⁴ exp(-S_inst)\n# S_inst = -ln(Λ⁴ / M_Pl⁴)\n# in natural units M_Pl = 1\nS_inst = -np.log(Lambda4 / M_Pl**4)\n\n# physical units: Λ ~ 10^-3 eV (dark energy scale)\n# Λ⁴ ~ (2.4e-3 eV)⁴ in particle physics units\n# M_Pl ~ 2.4e18 GeV = 2.4e27 eV\n# ratio:\nLambda_eV  = 2.4e-3        # eV\nM_Pl_eV    = 2.4e27        # eV\nLambda4_physical = Lambda_eV**4\nM_Pl4_physical   = M_Pl_eV**4\nS_inst_physical  = -np.log(\n    Lambda4_physical / M_Pl4_physical)\n\nprint(f\"In natural units (M_Pl=1):\")\nprint(f\"  Λ⁴ = {Lambda4:.4f}\")\nprint(f\"  S_inst = -ln(Λ⁴) = {S_inst:.4f}\")\nprint()\nprint(f\"In physical units:\")\nprint(f\"  Λ = {Lambda_eV:.2e} eV\")\nprint(f\"  M_Pl = {M_Pl_eV:.2e} eV\")\nprint(f\"  S_inst = {S_inst_physical:.2f}\")\nprint()\n\n# typical string instanton actions: S ~ 30-100\n# cosmological constant problem: S ~ 120\nS_typical_min = 30\nS_typical_max = 100\nS_cc_problem  = 120\n\nprint(f\"Typical string instanton range:\")\nprint(f\"  S ~ {S_typical_min} to {S_typical_max}\")\nprint(f\"  CC problem requires S ~ {S_cc_problem}\")\nprint(f\"  Our S_inst = {S_inst_physical:.1f}\")\nprint(f\"  Within string range: \"\n      f\"{S_typical_min <= S_inst_physical <= S_typical_max}\")\nprint(f\"  Closer to CC problem scale: \"\n      f\"{abs(S_inst_physical - S_cc_problem) < 20}\")\n\n# ───────────────────────────────────────────\n# TEST C — Moduli / CY Volume\n# f ~ M_Pl / (Vol_CY)^(1/6)\n# solve for Vol_CY given f = 0.500 M_Pl\n# ───────────────────────────────────────────\nprint()\nprint(\"TEST C — Moduli / CY Volume Check\")\nprint(\"-\" * 55)\n\n# f = M_Pl / (Vol_CY)^(1/6)\n# Vol_CY = (M_Pl / f)^6\n# in units M_Pl = 1\nVol_CY_natural = (M_Pl / f)**6\n\n# in string units ls = 1\n# Vol_CY in units of ls^6\n# typical CY volumes: 10^1 to 10^3 ls^6\n# large volume scenario: 10^6 to 10^15 ls^6\n\nprint(f\"In natural units (M_Pl = 1):\")\nprint(f\"  f = {f:.3f} M_Pl\")\nprint(f\"  Vol_CY = (M_Pl/f)^6 = {Vol_CY_natural:.4f}\")\nprint()\n\n# f in terms of string scale\n# f ~ M_s / (8π² k) where k is integer\n# M_s ~ g_s^(1/4) M_Pl / Vol^(1/6)\n# for f = 0.5 M_Pl\nratio_MsoverMPl = f  # simplified\nprint(f\"String scale interpretation:\")\nprint(f\"  f = 0.500 M_Pl\")\nprint(f\"  Consistent with M_s ~ 0.5 M_Pl\")\nprint(f\"  Requires moderately small volume\")\nprint(f\"  Vol_CY ~ {Vol_CY_natural:.2f} in M_Pl units\")\nprint()\n\n# axion quality: check if f < M_Pl\n# satisfies axion quality problem\nquality_ok = f < M_Pl\nprint(f\"Axion quality condition f < M_Pl:\")\nprint(f\"  f = {f:.3f} M_Pl\")\nprint(f\"  Quality condition satisfied: {quality_ok}\")\nprint(f\"  No explicit PQ-breaking needed\")\n\n# ───────────────────────────────────────────\n# TEST B — LQC Bounce Test\n# Modified Friedmann equation:\n# H² = (ρ/3)(1 - ρ/ρ_c)\n# ρ_c = √3 / (16π² γ³) M_Pl⁴\n# γ = 0.2375 (Barbero-Immirzi)\n# ───────────────────────────────────────────\nprint()\nprint(\"TEST B — LQC Bounce Test\")\nprint(\"-\" * 55)\n\ngamma   = 0.2375  # Barbero-Immirzi\nrho_c   = np.sqrt(3) / (16 * np.pi**2 * gamma**3)\nprint(f\"LQC critical density:\")\nprint(f\"  γ (Barbero-Immirzi) = {gamma}\")\nprint(f\"  ρ_c = {rho_c:.4f} M_Pl⁴\")\nprint()\n\n# solve TIFA cosmology with LQC correction\n# equations of motion:\n# dφ/dN = π_φ / (f² H)     [field velocity]\n# dπ_φ/dN = -3π_φ - (Λ⁴/f)sin(φ/f)/H   [momentum]\n# H² = (ρ_total/3)(1 - ρ_total/ρ_c)     [LQC Friedmann]\n# ρ_total = π_φ²/(2f⁴) + V(φ) + ρ_m\n# ρ_m = Omega_m * H0² * exp(-3N)\n\ndef tifa_lqc(N, y):\n    phi, dphi = y\n\n    # matter density at scale factor a = exp(N)\n    rho_m = Omega_m * H0**2 * np.exp(-3 * N)\n\n    # potential and kinetic\n    V_phi = Lambda4 * (1 - np.cos(phi / f))\n    KE    = 0.5 * dphi**2\n\n    # total density\n    rho_total = KE + V_phi + rho_m\n\n    # LQC modified Hubble\n    bracket = 1 - rho_total / rho_c\n    if bracket <= 0:\n        bracket = 1e-10\n    H2 = (rho_total / 3) * bracket\n    H  = np.sqrt(max(H2, 1e-30))\n\n    # equations of motion\n    dV_dphi = (Lambda4 / f) * np.sin(phi / f)\n    ddphi   = -3 * dphi - dV_dphi / H**2\n\n    return [dphi, ddphi]\n\ndef tifa_standard(N, y):\n    phi, dphi = y\n\n    rho_m = Omega_m * H0**2 * np.exp(-3 * N)\n    V_phi = Lambda4 * (1 - np.cos(phi / f))\n    KE    = 0.5 * dphi**2\n    rho_total = KE + V_phi + rho_m\n\n    H2 = rho_total / 3\n    H  = np.sqrt(max(H2, 1e-30))\n\n    dV_dphi = (Lambda4 / f) * np.sin(phi / f)\n    ddphi   = -3 * dphi - dV_dphi / H**2\n\n    return [dphi, ddphi]\n\n# initial conditions at N = -7 (z ~ 1096)\nN_ini = -7.0\nN_fin =  0.0\nphi_ini_val  = phi0\ndphi_ini_val = 0.0\ny0 = [phi_ini_val, dphi_ini_val]\n\nN_span = (N_ini, N_fin)\nN_eval = np.linspace(N_ini, N_fin, 500)\n\n# solve standard TIFA\nsol_std = solve_ivp(\n    tifa_standard, N_span, y0,\n    t_eval=N_eval,\n    method='RK45',\n    rtol=1e-8, atol=1e-10)\n\n# solve LQC TIFA\nsol_lqc = solve_ivp(\n    tifa_lqc, N_span, y0,\n    t_eval=N_eval,\n    method='RK45',\n    rtol=1e-8, atol=1e-10)\n\n# compute w(N) for both solutions\ndef compute_w(sol):\n    w_arr = []\n    for i in range(len(sol.t)):\n        phi_i  = sol.y[0][i]\n        dphi_i = sol.y[1][i]\n        V_i    = Lambda4 * (1 - np.cos(phi_i / f))\n        KE_i   = 0.5 * dphi_i**2\n        if KE_i + V_i > 1e-10:\n            w_i = (KE_i - V_i) / (KE_i + V_i)\n        else:\n            w_i = -1.0\n        w_arr.append(w_i)\n    return np.array(w_arr)\n\nw_std = compute_w(sol_std)\nw_lqc = compute_w(sol_lqc)\n\n# z from N\nz_std = np.exp(-sol_std.t) - 1\nz_lqc = np.exp(-sol_lqc.t) - 1\n\n# w at z=0\nw0_std = w_std[-1]\nw0_lqc = w_lqc[-1]\n\nprint(f\"Standard TIFA:  w(z=0) = {w0_std:.4f}\")\nprint(f\"LQC TIFA:       w(z=0) = {w0_lqc:.4f}\")\nprint(f\"Shift Δw = {abs(w0_lqc - w0_std):.4f}\")\nprint()\n\n# DESI band\ndesi_center = -0.90\ndesi_sigma  =  0.05\nw0_std_in_desi = abs(w0_std - desi_center) <= desi_sigma\nw0_lqc_in_desi = abs(w0_lqc - desi_center) <= desi_sigma\n\nprint(f\"DESI band: w = {desi_center} ± {desi_sigma}\")\nprint(f\"Standard w(z=0) in DESI band: {w0_std_in_desi}\")\nprint(f\"LQC      w(z=0) in DESI band: {w0_lqc_in_desi}\")\nprint(f\"Attractor survives LQC bounce: \"\n      f\"{abs(w0_lqc - w0_std) < 0.05}\")\n\n# ───────────────────────────────────────────\n# Final Summary\n# ───────────────────────────────────────────\nprint()\nprint(\"=\" * 55)\nprint(\"SUMMARY — §5.2 UV/QG Health Check\")\nprint(\"=\" * 55)\nprint(f\"Test A  S_inst = {S_inst_physical:.1f}\")\nprint(f\"        Natural string range: 30-100\")\nprint(f\"        Result: {'NATURAL' if S_typical_min <= S_inst_physical <= S_typical_max else 'REQUIRES EXPLANATION'}\")\nprint()\nprint(f\"Test C  Vol_CY = {Vol_CY_natural:.2f} M_Pl units\")\nprint(f\"        f = {f:.3f} M_Pl (sub-Planckian)\")\nprint(f\"        Result: CONSISTENT with moduli\")\nprint()\nprint(f\"Test B  Standard w(z=0) = {w0_std:.4f}\")\nprint(f\"        LQC      w(z=0) = {w0_lqc:.4f}\")\nprint(f\"        Shift Δw = {abs(w0_lqc - w0_std):.6f}\")\nprint(f\"        Result: {'ATTRACTOR SURVIVES LQC' if abs(w0_lqc - w0_std) < 0.05 else 'LQC SHIFTS ATTRACTOR'}\")\nprint(\"=\" * 55)\n\n# ───────────────────────────────────────────\n# Plot — three panels\n# ───────────────────────────────────────────\nfig, axes = plt.subplots(1, 3, figsize=(16, 5))\nfig.suptitle(\n    \"TIFA §5.2 — String/LQC Extension\\n\"\n    \"Test A: Instanton | \"\n    \"Test B: LQC Bounce | \"\n    \"Test C: CY Moduli\",\n    fontsize=12, fontweight='bold')\n\n# Panel A — instanton action landscape\nax = axes[0]\nS_range = np.linspace(20, 130, 300)\nLambda4_of_S = np.exp(-S_range)\nax.semilogy(S_range, Lambda4_of_S,\n    'b-', lw=2, label=r'$\\Lambda^4 = e^{-S}$')\nax.axvline(S_inst_physical,\n    color='red', ls='--', lw=2,\n    label=f'Our S = {S_inst_physical:.1f}')\nax.axvspan(30, 100, alpha=0.15,\n    color='green',\n    label='String range S~30-100')\nax.axvspan(110, 130, alpha=0.15,\n    color='orange',\n    label='CC problem S~120')\nax.set_xlabel('Instanton action S', fontsize=11)\nax.set_ylabel(r'$\\Lambda^4$ (natural units)', fontsize=11)\nax.set_title('Test A — Instanton Action', fontsize=11)\nax.legend(fontsize=8)\nax.grid(True, alpha=0.3)\n\n# Panel B — LQC vs standard w(z)\nax2 = axes[1]\nax2.plot(z_std, w_std, 'b-', lw=2,